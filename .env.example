# ============================================================
# Digital Legacy App — Django Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to Git.
# ============================================================

# ---- Django Core ----
DEBUG=True
SECRET_KEY=replace-with-50-random-chars-openssl-rand-base64-50
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
DATABASE_URL=postgresql://dl_user:dl_pass@localhost:5432/digital_legacy_dev

# ---- Redis ----
REDIS_URL=redis://:redis_dev_pass@localhost:6379/0

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081

# ---- JWT ----
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- Encryption ----
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=replace-with-64-hex-characters

# ---- Email (SMTP) ----
# For Gmail: Use an App Password (16 characters)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@digitallegacy.ng

# ---- AWS (S3 Storage) ----
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_S3_BUCKET_NAME=digital-legacy-vault-prod
AWS_KMS_KEY_ID=REPLACE_ME

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID=REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_PHONE_NUMBER=REPLACE_ME

# ---- Dead Man's Switch ----
DMS_DEFAULT_THRESHOLD_DAYS=90
DMS_DEFAULT_COOLING_OFF_DAYS=14

# ---- Logging ----
LOG_LEVEL=INFO

